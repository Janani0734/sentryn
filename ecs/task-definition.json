{
  "family": "sentryn-engine-task",
  "executionRoleArn": "arn:aws:iam::992382673899:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "engine",
      "image": "992382673899.dkr.ecr.ap-southeast-2.amazonaws.com/sentryn-engine:latest",
      "cpu": 0,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "engine-8000-tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "REDIS_HOST",
          "value": "172.31.40.11"
        },
        {
          "name": "QDRANT_HOST",
          "value": "172.31.4.204"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sentryn-engine-task",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "3072",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [],
  "placementConstraints": []
}
